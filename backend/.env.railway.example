# =============================================================================
# TechRen EDU — Railway environment variables (NEW service)
# =============================================================================
# Create a NEW Railway service. Do NOT overwrite the existing SMS / PWA backend.
# Copy these into Railway → Variables (generate your own secrets — never reuse SMS).
# =============================================================================

NODE_ENV=production

# Railway sets PORT automatically — you usually do not need to set it.
# PORT=8080

# MongoDB Atlas — prefer a SEPARATE database name from the SMS/PWA project
# e.g. ...mongodb.net/techren_edu?...
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/techren_edu?retryWrites=true&w=majority

# Access + refresh secrets must differ; each 32+ characters
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Founder seed (required in production — must NOT be Founder123!)
FOUNDER_EMAIL=founder@yourschool.com
FOUNDER_PASSWORD=replace-with-a-strong-unique-password

# Public URL of THIS Railway service (after you enable networking)
# Example: https://techren-edu-production.up.railway.app
FRONTEND_URL=https://YOUR-TECHREN-SERVICE.up.railway.app

GAMIFICATION_ENABLED=true
WALLET_ENABLED=false

# Optional: mount a Railway Volume at /data and set:
# UPLOADS_DIR=/data/uploads
