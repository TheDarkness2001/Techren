# Copy to .env.docker and fill in secrets before: docker compose --env-file .env.docker up -d
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
FOUNDER_PASSWORD=replace-with-a-strong-founder-password
FOUNDER_EMAIL=founder@techren.uz
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
GAMIFICATION_ENABLED=true
WALLET_ENABLED=false
FRONTEND_URL=https://app.techrenacademy.com
