NODE_ENV=development
PORT=5002

# Local MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/techren_edu

# Atlas example (replace user/password/host/db — never commit real credentials):
# MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DB_NAME?retryWrites=true&w=majority

# SEED_DEMO_DATA=false
# MONGO_FALLBACK_MEMORY=false
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# REQUIRED: long random strings. In production, JWT_REFRESH_SECRET must be set and distinct.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

FOUNDER_EMAIL=founder@techren.uz
FOUNDER_PASSWORD=replace-with-a-strong-password

GAMIFICATION_ENABLED=true
WALLET_ENABLED=false
# Production CORS allowlist — also allows *.techrenacademy.com
FRONTEND_URL=http://127.0.0.1:5000
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
